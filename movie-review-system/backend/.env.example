# Local backend on Windows host (postgres container published on host port 5433):
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/movie_review_db
#
# Backend running inside Docker Compose (use the postgres service hostname and internal port):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/movie_review_db
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ML_SERVICE_URL=http://127.0.0.1:8001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=true
