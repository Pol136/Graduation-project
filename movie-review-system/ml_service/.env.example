ML_SERVICE_VERSION=0.1.0
MODEL_VERSION=sentiment-rubert-tiny-v1
MODEL_PATH=./models
SENTIMENT_MODEL_NAME=cointegrated/rubert-tiny-sentiment-balanced
SENTIMENT_MAX_LENGTH=512
SENTIMENT_CHUNK_MAX_CHARS=900

ASPECT_MODEL_NAME=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
ASPECT_CONFIDENCE_THRESHOLD=0.55
ASPECT_MAX_SENTENCES=30
ASPECT_MULTI_LABEL=true
ASPECT_MODEL_VERSION=aspect-zero-shot-mdeberta-v1
ANALYSIS_MODEL_VERSION=sentiment-rubert-tiny-v1+aspect-zero-shot-mdeberta-v1

RATING_MODEL_PATH=rating_regressor.joblib
RATING_FEATURE_COLUMNS_PATH=rating_feature_columns.json
RATING_MODEL_METADATA_PATH=rating_model_metadata.json
RATING_MODEL_VERSION=rating-regressor-hgb-kinopoisk-v1
RATING_BASELINE_VERSION=rating-improved-baseline-v1

DATASETS_DIR=../datasets
PROCESSED_DATA_DIR=../datasets/processed

# Optional overrides for local training artifact paths
# SENTIMENT_MODEL_PATH=
# ABSA_MODEL_PATH=
# RECOMMENDER_MODEL_PATH=

HOST=0.0.0.0
PORT=8001
